# ---------------------------------------------------------------------------
# Matt Ryan QB Training — environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# ---------------------------------------------------------------------------

# Resend API key (https://resend.com/api-keys). Server-side only.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form inquiries are delivered (Matt's inbox). Server-side only.
CONTACT_TO_EMAIL=coach@yourdomain.com

# Verified Resend sender address (must be a domain verified in Resend).
# Server-side only.
CONTACT_FROM_EMAIL=inquiries@yourdomain.com

# Calendly scheduling link, e.g. https://calendly.com/your-handle/qb-session
# Public (exposed to the browser to render the inline embed).
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/qb-session
